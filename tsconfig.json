{
  "compilerOptions": {
    "module": "node20",
    "target": "es2020",

    "rootDir": "./src",
    "outDir": "./dist",

    "declaration": true,
    "sourceMap": true,

    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,

    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,

    "skipLibCheck": true,
    "incremental": true,

    "moduleResolution": "nodenext",
    "types": ["node"]
  }
}